<% content_for :title, "Users" %>

<div id="users" class="mt-12 flex justify-center px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-6xl space-y-6">

    <%= search_form_for @q, url: users_path, method: :get, html: { class: "bg-white shadow rounded-xl p-6" } do |f| %>
      <div class="flex flex-col md:flex-row md:items-end md:space-x-4 space-y-4 md:space-y-0">

        <div class="flex-1">
          <%= f.label :name_cont, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name_cont, placeholder: "Search by name...", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2" %>
        </div>

        <div class="flex-1">
          <%= f.label :email_cont, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :email_cont, placeholder: "Search by email...", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2" %>
        </div>

        <div class="flex-1">
          <%= f.label :role_eq, "Role", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :role_eq, User.distinct.pluck(:role).map { |r| [r.titleize, r] },
                        { include_blank: "All Roles" },
                        class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2" %>
        </div>

        <div>
          <%= f.submit "Apply", class: "bg-indigo-600 text-white px-5 py-2 rounded-lg shadow hover:bg-indigo-700 transition font-medium" %>
        </div>
      </div>
    <% end %>


    <div class="flex flex-wrap items-center justify-between bg-gradient-to-r from-gray-50 to-gray-100 p-4 rounded-lg shadow-sm">
      <span class="text-gray-700 font-medium">Sort by:</span>
      <div class="flex space-x-4 text-sm font-medium">
        <%= sort_link(@q, :name, "Name", default_order: :asc, class: "text-indigo-600 hover:text-indigo-800 transition") %>
        <%= sort_link(@q, :email, "Email", default_order: :asc, class: "text-indigo-600 hover:text-indigo-800 transition") %>
        <%= sort_link(@q, :created_at, "Date", default_order: :desc, class: "text-indigo-600 hover:text-indigo-800 transition") %>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl shadow-lg border border-gray-200">
      <table class="min-w-full divide-y divide-gray-200 text-sm sm:text-base">
        <thead class="bg-gray-100">
          <tr>
            <th class="py-3 px-4 text-left font-semibold text-gray-700">Name</th>
            <th class="py-3 px-4 text-left font-semibold text-gray-700">Email</th>
            <th class="py-3 px-4 text-left font-semibold text-gray-700">Role</th>
            <th class="py-3 px-4 text-center font-semibold text-gray-700" colspan="3">Actions</th>
            <th class="py-3 px-4 text-right">
              <% if current_user && policy(User).send_bulk_emails? %>
                <%= button_to "Send Bulk Emails", send_bulk_emails_users_path, method: :post, class: "px-4 py-2 rounded-full bg-blue-600 text-white hover:bg-blue-700 transition" %>
              <% end %>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="py-3 px-4 font-medium text-gray-800"><%= user.name %></td>
              <td class="py-3 px-4 text-gray-600"><%= user.email %></td>
              <td class="py-3 px-4 text-gray-600"><%= user.role %></td>
              <td class="py-3 px-4 text-center">
                <%= link_to user, class: "inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-500 text-white shadow hover:bg-blue-600 transition" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                       viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                <% end %>
              </td>

              <% if current_user && policy(user).update? %>
                <td class="py-3 px-4 text-center">
                  <%= link_to edit_user_path(user), class: "inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-600 text-white hover:bg-blue-700 transition" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.828A2 2 0 0110.414 14H9v-2z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 20H5a2 2 0 01-2-2V7a2 2 0 012-2h7" />
                    </svg>
                  <% end %>
                </td>


                <td class="py-3 px-4 text-center">
                  <button data-user-id="<%= user.id %>" data-user-name="<%= user.name %>" class="delete-btn inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-500 text-white shadow hover:bg-red-600 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M10 3h4a1 1 0 011 1v1H9V4a1 1 0 011-1z" />
                    </svg>
                  </button>
                </td>
              <% end %>

              <% if current_user && policy(user).send_email? %>
                <td class="py-3 px-4 text-center">
                  <%= button_to send_email_user_path(user), method: :post, class: "inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-600 text-white hover:bg-blue-700 transition" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 0v8a2 2 0 002 2h14a2 2 0 002-2V8m-18 0l9-6 9 6" />
                    </svg>
                  <% end %>
                </td>
              <% end %>

            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

<div class="flex justify-center mt-8 space-x-2">
  <%== pagy_nav(@pagy,
    link_extra:  'class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full hover:bg-blue-100 hover:text-blue-600 transition"',
    active_extra:'class="px-4 py-2 bg-blue-600 text-white rounded-full shadow"',
    prev_extra:  'class="px-3 py-2 bg-gray-100 text-gray-500 rounded-full hover:bg-gray-200"',
    next_extra:  'class="px-3 py-2 bg-gray-100 text-gray-500 rounded-full hover:bg-gray-200"',
    gap_extra:   'class="px-4 py-2 text-gray-400 rounded-full bg-gray-50 cursor-not-allowed"'
  ) %>
</div>


  </div>
</div>
