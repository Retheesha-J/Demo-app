<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
        <h1 class="text-3xl font-bold mb-6 text-center">Login</h1>
        <%=form_with url: login_path, scope: :user, local: true do |form| %>

        <div class="flex flex-col">
            <%= form.label :email,class: "mb-1 font-semibold" %>
            <%= form.email_field :email , class: "border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true%>
        </div>
        <div class="flex flex-col">
            <%= form.label :password,class: "mb-1 font-semibold"%>
            <%= form.password_field :password, class: "border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
        </div>

        <div class="flex items-center justify-center">
           <%= form.submit "Login", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition mt-3" %>
        </div>
    </div>
</div>
<% end %>
