<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-200 via-white to-amber-100 px-4 py-12">
  <div id="<%= dom_id user %>" 
       class="relative w-full max-w-md bg-white rounded-3xl shadow-2xl border border-indigo-100 p-10 overflow-hidden">


    <div class="absolute -top-12 -left-12 w-40 h-40 bg-indigo-400 rounded-full opacity-20 blur-3xl"></div>
    <div class="absolute -bottom-12 -right-12 w-40 h-40 bg-amber-400 rounded-full opacity-20 blur-3xl"></div>


    <h2 class="text-3xl font-extrabold text-center bg-gradient-to-r from-indigo-600 to-amber-500 bg-clip-text text-transparent mb-8">
      User Profile
    </h2>

    <div class="space-y-6 text-center">
      <div>
        <p class="text-sm uppercase text-gray-500">Name</p>
        <p class="text-lg font-semibold text-gray-800"><%= user.name %></p>
      </div>

      <div>
        <p class="text-sm uppercase text-gray-500">Email</p>
        <p class="text-lg font-semibold text-gray-800"><%= user.email %></p>
      </div>

      <div>
        <p class="text-sm uppercase text-gray-500">Password</p>
        <p class="text-lg font-semibold text-gray-800">••••••••</p>
      </div>
        <div>
      <div id="reset-password-link" class="hidden mt-4">
        <%= link_to "Reset Password", edit_user_registration_path,
                    class: "text-blue-600 hover:underline" %>
      </div>
    </div>

    <div class="mt-10 flex justify-center">
      <%= link_to users_path,
          class: "inline-flex items-center space-x-2 bg-gradient-to-r from-indigo-500 to-amber-500 text-white px-6 py-3 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transform transition-all duration-300" do %>
        <!-- Back Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 19l-7-7 7-7" />
        </svg>
        <span class="font-medium">Back</span>
      <% end %>
    </div>
  </div>
</div>
