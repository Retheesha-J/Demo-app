<div class="flex-1 flex items-center justify-center bg-gray-100">
  <div id="<%= dom_id user %>" 
        class="w-full max-w-sm sm:max-w-md bg-white rounded-2xl shadow-xl p-8 border border-gray-200 overflow-hidden">
       
    <h2 class="text-2xl font-semibold text-gray-800 mb-6 text-center">User Info</h2>

    <div class="space-y-4">
      <p class="text-gray-700">
        <span class="font-medium text-gray-900">Name:</span>
        <%= user.name %>
      </p>

      <p class="text-gray-700">
        <span class="font-medium text-gray-900">Email:</span>
        <%= user.email %>
      </p>

      <p class="text-gray-700">
        <span class="font-medium text-gray-900">Password:</span>
        ••••••••
      </p>
    </div>

    <div class="mt-6 flex justify-center">
      <%= link_to "Back", users_path, class: "inline-block bg-blue-500 text-white px-6 py-2 rounded-lg hover:bg-blue-600 transition" %>
    </div>
  </div>
</div>
