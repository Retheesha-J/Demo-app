
<div class="min-h-screen bg-gray-50 flex items-center justify-center">
  <div class="max-w-2xl w-full bg-white rounded-2xl shadow-lg p-8 text-center">
    
    <h1 class="text-3xl font-bold text-gray-800 mb-4">
      Welcome to User Management App
    </h1>
    
    <p class="text-gray-600 mb-6">
      Manage users easily with create, read, update, and delete functionality.
    </p>
    
    <div class="flex justify-center space-x-4">
      <%= link_to "View Users", users_path, 
          class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg shadow hover:bg-blue-700" %>
      <% if current_user&.role=="admin" %>
        <%= link_to "Add New User", new_user_path, 
          class: "px-6 py-2 bg-green-600 text-white font-medium rounded-lg shadow hover:bg-green-700" %>
      <% end %>
    </div>
    
  </div>
</div>
