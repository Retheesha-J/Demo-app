<h1 class="text-2xl font-bold mb-6 text-center mt-5">Upload Document</h1>

<div class="flex justify-center">
  <div class="w-full max-w-md bg-white shadow-lg rounded-xl p-6">
    <%= form_with(model: @document, local: true, html: { multipart: true, class: "space-y-4" }) do |f| %>
      <div class="flex flex-col">
        <%= f.label :title, class: "mb-1 font-medium text-gray-700" %>
        <%= f.text_field :title, class: "border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-indigo-500 focus:outline-none" %>
        <% if @document.errors[:title].any? %>
          <span class="text-red-600 text-sm mt-1"><%= @document.errors[:title].first %></span>
        <% end %>
      </div>

      <div class="flex flex-col">
        <%= f.label :file, class: "mb-1 font-medium text-gray-700" %>
        <%= f.file_field :file, class: "border border-gray-300 rounded-lg p-2" %>
        <% if @document.errors[:file].any? %>
          <span class="text-red-600 text-sm mt-1"><%= @document.errors[:file].first %></span>
        <% end %>
      </div>

      <div class="text-center">
        <%= f.submit "Upload", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg shadow hover:bg-indigo-700 transition font-medium" %>
      </div>
    <% end %>
  </div>
</div>
