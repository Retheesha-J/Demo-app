<div class="min-h-screen flex items-center justify-center bg-gradient-to-r from-blue-100 to-indigo-200 px-4">
  <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md">

    <h1 class="text-3xl font-extrabold mb-6 text-center text-gray-800">
      Change your password
    </h1>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), 
                 html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <!-- New password -->
      <div class="mb-4">
        <%= f.label :password, "New Password", class: "block mb-2 text-sm font-medium text-gray-700" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mb-2">(<%= @minimum_password_length %> characters minimum)</p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 
                     focus:outline-none focus:ring-2 focus:ring-blue-500 
                     focus:border-blue-500" %>
      </div>

      <!-- Confirm password -->
      <div class="mb-6">
        <%= f.label :password_confirmation, "Confirm New Password", class: "block mb-2 text-sm font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 
                     focus:outline-none focus:ring-2 focus:ring-blue-500 
                     focus:border-blue-500" %>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Change my password", 
              class: "w-full bg-blue-600 text-white py-2 px-4 rounded-lg 
                     font-semibold hover:bg-blue-700 transition duration-200 shadow-md" %>
      </div>
    <% end %>

    <!-- Extra Links -->
    <div class="mt-6 text-center text-sm text-gray-600">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
